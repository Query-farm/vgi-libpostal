# name: test/sql/expand.test
# description: expand_address LIST scalar (normalized expansions)
# group: [vgi_libpostal]

require-env VGI_LIBPOSTAL_WORKER

statement ok
LOAD vgi;

statement ok
ATTACH 'postal' AS postal (TYPE vgi, LOCATION '${VGI_LIBPOSTAL_WORKER}');

# ---- expand_address(text) -> VARCHAR[] ----
# 'E' expands to 'east' and 'St' to 'street' in at least one expansion.

query I
SELECT count(*) > 0 FROM (SELECT UNNEST(postal.expand_address('120 E 96th St')) AS e) WHERE e LIKE '%east%';
----
true

query I
SELECT count(*) > 0 FROM (SELECT UNNEST(postal.expand_address('120 E 96th St')) AS e) WHERE e LIKE '%street%';
----
true

# At least one expansion is produced.
query I
SELECT len(postal.expand_address('120 E 96th St')) > 0;
----
true

# Empty string -> empty list, NOT an error.
query I
SELECT len(postal.expand_address(''));
----
0

# NULL input -> NULL list.
query I
SELECT postal.expand_address(NULL) IS NULL;
----
true

statement ok
DETACH postal;
